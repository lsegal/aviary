{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Aviary Configuration",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "server": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "default": 16677,
          "x-label": "Port",
          "x-placeholder": "16677",
          "x-order": 1,
          "description": "HTTP(S) listen port. Defaults to 16677."
        },
        "external_access": {
          "type": "boolean",
          "x-label": "External access",
          "x-order": 2,
          "description": "Bind the Aviary server to 0.0.0.0 instead of localhost."
        },
        "no_tls": {
          "type": "boolean",
          "x-label": "Disable TLS",
          "x-order": 3,
          "description": "Disable TLS and serve plain HTTP. Intended for trusted local or reverse-proxy environments."
        },
        "tls": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cert": {
              "type": "string",
              "x-label": "TLS cert path",
              "x-placeholder": "/path/to/cert.pem",
              "x-order": 4,
              "description": "Path to TLS certificate file (PEM). Leave empty to use an auto-generated self-signed cert."
            },
            "key": {
              "type": "string",
              "x-label": "TLS key path",
              "x-placeholder": "/path/to/key.pem",
              "x-order": 5,
              "description": "Path to TLS private key file (PEM). Leave empty to use an auto-generated self-signed key."
            }
          }
        }
      }
    },
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "model": { "type": "string" },
          "memory": { "type": "string" },
          "rules": {
            "type": "string",
            "description": "Inline operating rules or a path to a markdown file whose contents are injected into the agent system prompt."
          },
          "memory_tokens": {
            "type": "integer",
            "minimum": 1,
            "default": 4000,
            "description": "Maximum tokens of memory context to include in each prompt."
          },
          "compact_keep": {
            "type": "integer",
            "minimum": 1,
            "default": 200,
            "description": "Number of memory entries allowed before the pool is compacted into a single summary."
          },
          "fallbacks": {
            "type": "array",
            "items": { "type": "string" }
          },
          "permissions": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "preset": {
                "type": "string",
                "enum": ["full", "standard", "minimal"],
                "description": "Maximum tool groups this agent may use. Defaults to standard when omitted."
              },
              "tools": {
                "type": "array",
                "items": { "type": "string" }
              },
              "disabled_tools": {
                "type": "array",
                "items": { "type": "string" }
              },
              "filesystem": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "allowed_paths": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              },
              "exec": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "allowed_commands": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "shell_interpolate": { "type": "boolean", "default": false },
                  "shell": { "type": "string" }
                }
              }
            }
          },
          "channels": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type"],
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" },
                "type": {
                  "type": "string",
                  "enum": ["slack", "discord", "signal"]
                },
                "token": { "type": "string" },
                "id": { "type": "string" },
                "url": {
                  "type": "string",
                  "description": "TCP address of an existing signal-cli JSON-RPC daemon (e.g. 127.0.0.1:7583). If omitted for Signal channels, signal-cli is launched and managed automatically."
                },
                "show_typing": { "type": "boolean" },
                "reply_to_replies": { "type": "boolean" },
                "react_to_emoji": { "type": "boolean" },
                "send_read_receipts": { "type": "boolean" },
                "model": { "type": "string" },
                "fallbacks": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "disabled_tools": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "allow_from": {
                  "type": "array",
                  "items": {
                    "oneOf": [
                      { "type": "string" },
                      {
                        "type": "object",
                        "required": ["from"],
                        "properties": {
                          "enabled": { "type": "boolean" },
                          "from": { "type": "string" },
                          "allowed_groups": {
                            "type": "string",
                            "description": "Comma-separated group/channel IDs. Use '*' to allow any group. When empty, only matches direct messages."
                          },
                          "mention_prefixes": {
                            "type": "array",
                            "items": { "type": "string" },
                            "description": "Glob patterns matched against group message text. At least one must match to forward the message."
                          },
                          "respond_to_mentions": { "type": "boolean" },
                          "restrict_tools": {
                            "type": "array",
                            "items": { "type": "string" }
                          },
                          "model": { "type": "string" },
                          "fallbacks": {
                            "type": "array",
                            "items": { "type": "string" }
                          }
                        }
                      }
                    ]
                  }
                }
              }
            }
          },
          "tasks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name"],
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" },
                "name": { "type": "string" },
                "type": {
                  "type": "string",
                  "enum": ["prompt", "script"]
                },
                "schedule": { "type": "string" },
                "start_at": { "type": "string", "format": "date-time" },
                "run_once": { "type": "boolean", "default": false },
                "watch": { "type": "string" },
                "prompt": { "type": "string" },
                "script": { "type": "string" },
                "target": { "type": "string" }
              },
              "allOf": [
                {
                  "oneOf": [
                    { "required": ["schedule"] },
                    { "required": ["watch"] }
                  ]
                },
                {
                  "if": {
                    "properties": { "type": { "const": "script" } }
                  },
                  "then": {
                    "required": ["script"]
                  }
                },
                {
                  "if": {
                    "properties": { "type": { "const": "prompt" } }
                  },
                  "then": {
                    "required": ["prompt"]
                  }
                }
              ]
            }
          }
        }
      }
    },
    "models": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "providers": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "auth": { "type": "string" }
            }
          }
        },
        "defaults": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "model": {
              "type": "string",
              "x-label": "Default model",
              "x-placeholder": "claude-opus-4-6",
              "x-order": 1,
              "description": "Fallback model used when an agent does not specify one."
            },
            "fallbacks": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "browser": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "binary": {
          "type": "string",
          "x-label": "Browser binary",
          "x-placeholder": "auto-detected",
          "x-order": 1,
          "description": "Path to Chrome/Chromium binary. Leave empty to auto-detect."
        },
        "cdp_port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "default": 9222,
          "x-label": "CDP port",
          "x-placeholder": "9222",
          "x-order": 2,
          "description": "Chrome DevTools Protocol port used to attach to an existing browser instance."
        },
        "profile_directory": {
          "type": "string",
          "x-label": "Profile directory",
          "x-placeholder": "Aviary",
          "x-order": 3,
          "description": "Chrome profile folder name in the browser's default user data directory (e.g. 'Default', 'Profile 1', 'work'). Defaults to 'Aviary' if unset."
        },
        "headless": {
          "type": "boolean",
          "default": false,
          "x-label": "Headless mode",
          "x-order": 4,
          "description": "Run the browser without a visible window. Defaults to false so the browser is visible."
        },
        "reuse_tabs": {
          "type": "boolean",
          "default": true,
          "x-label": "Reuse matching tabs",
          "x-order": 5,
          "description": "When enabled, browser_open reuses an existing page tab if the requested URL exactly matches the current URL. Defaults to true."
        }
      }
    },
    "search": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "web": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "brave_api_key": {
              "type": "string",
              "x-label": "Brave API key ref",
              "x-placeholder": "auth:brave_api_key",
              "x-order": 1,
              "description": "Brave Search API key or auth store reference (e.g. 'auth:brave_api_key'). Leave empty to disable web search."
            }
          }
        }
      }
    },
    "scheduler": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "concurrency": {
          "oneOf": [
            { "type": "string", "enum": ["auto"] },
            { "type": "integer", "minimum": 1 }
          ],
          "x-label": "Concurrency",
          "x-placeholder": "auto",
          "x-order": 1,
          "description": "Number of parallel task workers. Use 'auto' (or leave empty) to match the CPU count."
        }
      }
    },
    "skills": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean" },
          "settings": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    }
  }
}
