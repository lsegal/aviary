{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Aviary Configuration",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "server": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "default": 16677
        },
        "external_access": {
          "type": "boolean",
          "description": "Bind the Aviary server to 0.0.0.0 instead of localhost."
        },
        "no_tls": {
          "type": "boolean",
          "description": "Disable TLS and serve plain HTTP. Intended for trusted local or reverse-proxy environments."
        },
        "tls": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cert": { "type": "string" },
            "key": { "type": "string" }
          }
        }
      }
    },
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "model": { "type": "string" },
          "memory": { "type": "string" },
          "rules": {
            "type": "string",
            "description": "Inline operating rules or a path to a markdown file whose contents are injected into the agent system prompt."
          },
          "memory_tokens": {
            "type": "integer",
            "minimum": 1,
            "default": 4000,
            "description": "Maximum tokens of memory context to include in each prompt."
          },
          "compact_keep": {
            "type": "integer",
            "minimum": 1,
            "default": 200,
            "description": "Number of recent memory entries to retain after compaction."
          },
          "fallbacks": {
            "type": "array",
            "items": { "type": "string" }
          },
          "permissions": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "preset": {
                "type": "string",
                "enum": ["full", "standard", "minimal"],
                "description": "Maximum tool groups this agent may use. Defaults to standard when omitted."
              },
              "tools": {
                "type": "array",
                "items": { "type": "string" }
              },
            "disabledTools": {
              "type": "array",
              "items": { "type": "string" }
            },
              "filesystem": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "allowedPaths": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              },
              "exec": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "allowedCommands": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "shellInterpolate": { "type": "boolean", "default": false },
                  "shell": { "type": "string" }
                }
              }
            }
          },
          "channels": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type"],
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" },
                "type": {
                  "type": "string",
                  "enum": ["slack", "discord", "signal"]
                },
                "token": { "type": "string" },
                "channel": { "type": "string" },
                "phone": { "type": "string" },
                "url": {
                  "type": "string",
                  "description": "TCP address of an existing signal-cli JSON-RPC daemon (e.g. 127.0.0.1:7583). If omitted for Signal channels, signal-cli is launched and managed automatically."
                },
                "enabledAt": { "type": "string", "format": "date-time" },
                "disabledAt": { "type": "string", "format": "date-time" },
                "showTyping": { "type": "boolean" },
                "replyToReplies": { "type": "boolean" },
                "reactToEmoji": { "type": "boolean" },
                "sendReadReceipts": { "type": "boolean" },
                "model": { "type": "string" },
                "fallbacks": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "disabledTools": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "allowFrom": {
                  "type": "array",
                  "items": {
                    "oneOf": [
                      { "type": "string" },
                      {
                        "type": "object",
                        "required": ["from"],
                        "properties": {
                          "enabled": { "type": "boolean" },
                          "from": { "type": "string" },
                          "allowedGroups": { "type": "string" },
                          "mentionPrefixes": {
                            "type": "array",
                            "items": { "type": "string" }
                          },
                          "respondToMentions": { "type": "boolean" },
                          "restrictTools": {
                            "type": "array",
                            "items": { "type": "string" }
                          },
                          "model": { "type": "string" },
                          "fallbacks": {
                            "type": "array",
                            "items": { "type": "string" }
                          }
                        }
                      }
                    ]
                  }
                }
              }
            }
          },
          "tasks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "prompt"],
              "additionalProperties": false,
              "properties": {
                "name": { "type": "string" },
                "schedule": { "type": "string" },
                "start_at": { "type": "string", "format": "date-time" },
                "run_once": { "type": "boolean", "default": false },
                "watch": { "type": "string" },
                "prompt": { "type": "string" },
                "channel": { "type": "string" }
              },
              "oneOf": [
                { "required": ["schedule"] },
                { "required": ["watch"] }
              ]
            }
          }
        }
      }
    },
    "models": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "providers": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "auth": { "type": "string" }
            }
          }
        },
        "defaults": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "model": { "type": "string" },
            "fallbacks": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "browser": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "binary": { "type": "string" },
        "cdp_port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "default": 9222
        },
        "profile_directory": {
          "type": "string",
          "description": "Chrome profile folder name in the browser's default user data directory (e.g. 'Default', 'Profile 1', 'work'). Defaults to 'Aviary' if unset."
        },
        "headless": {
          "type": "boolean",
          "default": false,
          "description": "Run the browser without a visible window. Defaults to false so the browser is visible."
        }
      }
    },
    "search": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "web": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "brave_api_key": { "type": "string" }
          }
        }
      }
    },
    "scheduler": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "concurrency": {
          "oneOf": [
            { "type": "string", "enum": ["auto"] },
            { "type": "integer", "minimum": 1 }
          ]
        }
      }
    },
    "skills": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean" },
          "binary": { "type": "string" },
          "allowed_commands": {
            "type": "array",
            "items": { "type": "string" }
          },
          "env": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "timeout": { "type": "string" }
        }
      }
    }
  }
}
