{
	"name": "aviary-web",
	"version": "0.1.0",
	"private": true,
	"packageManager": "pnpm@8.6.0",
	"type": "module",
	"scripts": {
		"dev": "concurrently -n vite,go -c cyan,green \"vite\" \"wgo run ./cmd/aviary start\"",
		"dev:ci": "concurrently -n vite,go -c cyan,green \"vite\" \"./aviary start\"",
		"build": "vue-tsc --noEmit && vite build && pnpm run build:copy && pnpm run build:go",
		"build:web": "vue-tsc --noEmit && vite build && pnpm run build:copy",
		"build:go": "go build -ldflags \"-X github.com/lsegal/aviary/internal/server.Version=$(git describe --tags --always --dirty 2>/dev/null || echo dev)\" -o aviary ./cmd/aviary",
		"build:copy": "mkdir -p internal/server/webdist && cp -r web/dist/. internal/server/webdist/",
		"build:generate": "go generate ./...",
		"build:clean": "rm -f aviary && rm -rf web/dist internal/server/webdist",
		"preview": "vite preview",
		"lint": "pnpm lint:go && pnpm lint:web",
		"lint:go": "golangci-lint run ./...",
		"lint:web": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"test": "pnpm lint && pnpm test:go && pnpm test:e2e",
		"test:go": "go test ./...",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui"
	},
	"dependencies": {
		"marked": "^17.0.3",
		"pinia": "^3.0.4",
		"vue": "^3.5.29",
		"vue-router": "^5.0.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@playwright/test": "^1.58.2",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.1",
		"@types/node": "^25.3.5",
		"@vitejs/plugin-vue": "^6.0.4",
		"autoprefixer": "^10.4.27",
		"concurrently": "^9.2.1",
		"postcss": "^8.5.8",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vue-tsc": "^3.2.5"
	}
}
