{
	"name": "aviary-web",
	"version": "0.1.0",
	"private": true,
	"packageManager": "pnpm@8.6.0",
	"type": "module",
	"scripts": {
		"claude": "claude --dangerously-skip-permissions",
		"codex": "codex --dangerously-bypass-approvals-and-sandbox",
		"dev": "concurrently -n vite,go -c cyan,green \"vite\" \"wgo run ./cmd/aviary start\"",
		"build": "pnpm run build:web && pnpm run build:go",
		"build:web": "vue-tsc --noEmit && vite build && pnpm run build:copy",
		"build:go": "node scripts/build-go.mjs",
		"build:copy": "node scripts/build-webdist.mjs",
		"build:release": "pnpm run build:web && node scripts/build-release.mjs",
		"build:generate": "go generate ./...",
		"build:clean": "node scripts/clean.mjs",
		"preview": "vite preview",
		"lint": "pnpm lint:go && pnpm lint:web",
		"lint:go": "go run github.com/golangci/golangci-lint/v2/cmd/golangci-lint@v2.1.2 run ./...",
		"lint:web": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"test": "pnpm lint && pnpm test:go && pnpm test:e2e",
		"test:go": "go test ./...",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"release:prepare": "pnpm exec vpr run -f --include-artifact dist/release/ pnpm release:package",
		"release:package": "node scripts/release-package.mjs",
		"release": "pnpm exec vpr run -c pnpm release:stage && git pull",
		"release:stage": "node scripts/release-stage.mjs",
		"release:major": "cross-env VERSION=major pnpm release:prepare && pnpm release",
		"release:minor": "cross-env VERSION=minor pnpm release:prepare && pnpm release",
		"release:patch": "cross-env VERSION=patch pnpm release:prepare && pnpm release"
	},
	"dependencies": {
		"marked": "^17.0.4",
		"pinia": "^3.0.4",
		"radix-vue": "^1.9.17",
		"vue": "^3.5.30",
		"vue-router": "^5.0.4"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@playwright/test": "^1.58.2",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.5.0",
		"@vitejs/plugin-vue": "^6.0.5",
		"autoprefixer": "^10.4.27",
		"concurrently": "^9.2.1",
		"cross-env": "^10.1.0",
		"postcss": "^8.5.8",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vpr": "^1.4.5",
		"vue-tsc": "^3.2.6"
	}
}
