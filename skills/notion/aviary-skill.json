{
  "runtime": {
    "type": "command",
    "binary": "notion-cli",
    "binary_setting": "binary",
    "args": ["--json"],
    "strip_args": ["--json"],
    "allowed_commands_setting": "allowed_commands",
    "allowed_commands": [
      "auth",
      "page",
      "db",
      "search",
      "comment",
      "tools"
    ]
  },
  "settings": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "binary": {
        "type": "string",
        "title": "Binary override",
        "description": "Optional path or command name for the notion-cli binary.",
        "placeholder": "notion-cli"
      },
      "allowed_commands": {
        "type": "array",
        "title": "Allowed commands",
        "description": "Top-level notion-cli commands that Aviary may invoke.",
        "items": {
          "type": "string"
        },
        "placeholder": "search, page, db"
      }
    }
  }
}
