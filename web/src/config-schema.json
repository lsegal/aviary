{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Aviary Configuration",
	"type": "object",
	"additionalProperties": false,
	"properties": {
		"server": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"port": {
					"type": "integer",
					"minimum": 1,
					"maximum": 65535,
					"default": 16677
				},
				"external_access": {
					"type": "boolean",
					"description": "Bind the Aviary server to 0.0.0.0 instead of localhost."
				},
				"no_tls": {
					"type": "boolean",
					"description": "Disable TLS and serve plain HTTP. Intended for trusted local or reverse-proxy environments."
				},
				"tls": {
					"type": "object",
					"additionalProperties": false,
					"properties": {
						"cert": { "type": "string" },
						"key": { "type": "string" }
					}
				}
			}
		},
		"agents": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["name"],
				"additionalProperties": false,
				"properties": {
					"name": { "type": "string" },
					"model": { "type": "string" },
					"memory": { "type": "string" },
					"rules": {
						"type": "string",
						"description": "Inline operating rules or a path to a markdown file whose contents are injected into the agent system prompt."
					},
					"memory_tokens": {
						"type": "integer",
						"minimum": 1,
						"default": 4000,
						"description": "Maximum tokens of memory context to include in each prompt."
					},
					"compact_keep": {
						"type": "integer",
						"minimum": 1,
						"default": 200,
						"description": "Number of memory entries allowed before the pool is compacted into a single summary."
					},
					"fallbacks": {
						"type": "array",
						"items": { "type": "string" }
					},
					"permissions": {
						"type": "object",
						"additionalProperties": false,
						"properties": {
							"preset": {
								"type": "string",
								"enum": ["full", "standard", "minimal"],
								"description": "Maximum tool groups this agent may use. Defaults to standard when omitted."
							},
							"tools": {
								"type": "array",
								"items": { "type": "string" }
							},
							"disabled_tools": {
								"type": "array",
								"items": { "type": "string" }
							},
							"filesystem": {
								"type": "object",
								"additionalProperties": false,
								"properties": {
									"allowed_paths": {
										"type": "array",
										"items": { "type": "string" }
									}
								}
							},
							"exec": {
								"type": "object",
								"additionalProperties": false,
								"properties": {
									"allowed_commands": {
										"type": "array",
										"items": { "type": "string" }
									},
									"shell_interpolate": { "type": "boolean", "default": false },
									"shell": { "type": "string" }
								}
							}
						}
					},
					"channels": {
						"type": "array",
						"items": {
							"type": "object",
							"required": ["type"],
							"additionalProperties": false,
							"properties": {
								"enabled": { "type": "boolean" },
								"type": {
									"type": "string",
									"enum": ["slack", "discord", "signal"]
								},
								"token": { "type": "string" },
								"id": { "type": "string" },
								"url": {
									"type": "string",
									"description": "TCP address of an existing signal-cli JSON-RPC daemon (e.g. 127.0.0.1:7583). If omitted for Signal channels, signal-cli is launched and managed automatically."
								},
								"show_typing": { "type": "boolean" },
								"reply_to_replies": { "type": "boolean" },
								"react_to_emoji": { "type": "boolean" },
								"send_read_receipts": { "type": "boolean" },
								"group_chat_history": {
									"type": "integer",
									"description": "Number of recent group chat messages to log and provide as context to the agent. 0 means use the default (50). Set to -1 to disable."
								},
								"model": { "type": "string" },
								"fallbacks": {
									"type": "array",
									"items": { "type": "string" }
								},
								"disabled_tools": {
									"type": "array",
									"items": { "type": "string" }
								},
								"allow_from": {
									"type": "array",
									"items": {
										"oneOf": [
											{ "type": "string" },
											{
												"type": "object",
												"required": ["from"],
												"properties": {
													"enabled": { "type": "boolean" },
													"from": { "type": "string" },
													"allowed_groups": { "type": "string" },
													"mention_prefixes": {
														"type": "array",
														"items": { "type": "string" }
													},
													"respond_to_mentions": { "type": "boolean" },
													"restrict_tools": {
														"type": "array",
														"items": { "type": "string" }
													},
													"model": { "type": "string" },
													"fallbacks": {
														"type": "array",
														"items": { "type": "string" }
													}
												}
											}
										]
									}
								}
							}
						}
					},
					"tasks": {
						"type": "array",
						"items": {
							"type": "object",
							"required": ["name", "prompt"],
							"additionalProperties": false,
							"properties": {
								"enabled": { "type": "boolean" },
								"name": { "type": "string" },
								"type": {
									"type": "string",
									"enum": ["prompt", "script"]
								},
								"schedule": { "type": "string" },
								"start_at": { "type": "string", "format": "date-time" },
								"run_once": { "type": "boolean", "default": false },
								"watch": { "type": "string" },
								"prompt": { "type": "string" },
								"script": { "type": "string" },
								"target": { "type": "string" }
							},
							"allOf": [
								{
									"oneOf": [
										{ "required": ["schedule"] },
										{ "required": ["watch"] }
									]
								},
								{
									"if": {
										"properties": { "type": { "const": "script" } }
									},
									"then": {
										"required": ["script"]
									}
								},
								{
									"if": {
										"properties": { "type": { "const": "prompt" } }
									},
									"then": {
										"required": ["prompt"]
									}
								}
							]
						}
					}
				}
			}
		},
		"models": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"providers": {
					"type": "object",
					"additionalProperties": {
						"type": "object",
						"additionalProperties": false,
						"properties": {
							"auth": { "type": "string" },
							"base_uri": { "type": "string" }
						}
					}
				},
				"defaults": {
					"type": "object",
					"additionalProperties": false,
					"properties": {
						"model": { "type": "string" },
						"fallbacks": {
							"type": "array",
							"items": { "type": "string" }
						}
					}
				}
			}
		},
		"browser": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"binary": { "type": "string" },
				"cdp_port": {
					"type": "integer",
					"minimum": 1,
					"maximum": 65535,
					"default": 9222
				},
				"profile_directory": {
					"type": "string",
					"description": "Chrome profile folder name in the browser's default user data directory (e.g. 'Default', 'Profile 1', 'work'). Defaults to 'Aviary' if unset."
				},
				"headless": {
					"type": "boolean",
					"default": false,
					"description": "Run the browser without a visible window. Defaults to false so the browser is visible."
				}
			}
		},
		"search": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"web": {
					"type": "object",
					"additionalProperties": false,
					"properties": {
						"brave_api_key": { "type": "string" }
					}
				}
			}
		},
		"scheduler": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"concurrency": {
					"oneOf": [
						{ "type": "string", "enum": ["auto"] },
						{ "type": "integer", "minimum": 1 }
					]
				}
			}
		},
		"skills": {
			"type": "object",
			"additionalProperties": {
				"type": "object",
				"additionalProperties": false,
				"properties": {
					"enabled": { "type": "boolean" },
					"settings": {
						"type": "object",
						"additionalProperties": true
					}
				}
			}
		}
	}
}
